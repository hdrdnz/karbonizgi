                },
                "text": {
                    "type": "string"
                }
            }
        },
        "controllers.PersonInf": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "score": {
                    "type": "string"
                },
                "userId": {
                    "type": "integer"
                }
            }
        },
        "controllers.QuesInf": {
            "type": "object",
            "properties": {
                "key": {
                    "type": "string"
                },
                "options": {
